<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="@dimen/ar_margin_big"
    android:paddingEnd="@dimen/ar_margin_big"
    android:paddingTop="@dimen/ar_margin_normal"
    android:paddingBottom="@dimen/ar_margin_big"
    android:gravity="center_horizontal">

    <View
        android:layout_width="@dimen/ar_drag_handle_width"
        android:layout_height="@dimen/ar_drag_handle_height"
        android:layout_marginBottom="@dimen/ar_margin_normal"
        android:background="@drawable/ar_bg_drag_handle"/>

    <ImageView
        android:id="@+id/ar_icon"
        android:layout_width="@dimen/ar_icon_size_large"
        android:layout_height="@dimen/ar_icon_size_large"
        android:layout_marginBottom="@dimen/ar_margin_normal"
        android:contentDescription="@string/ar_cd_app_icon"/>

    <TextView
        android:id="@+id/ar_title"
        style="@style/AR.TextAppearance.HeadlineLarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/ar_margin_small"
        android:text="@string/ar_title_overview_binary"
        android:gravity="center"/>

    <TextView
        android:id="@+id/ar_message"
        style="@style/AR.TextAppearance.Body"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/ar_margin_big"
        android:text="@string/ar_message_overview"
        android:gravity="center"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="@dimen/ar_margin_normal"
        android:weightSum="2">

        <LinearLayout
            android:id="@+id/ar_love_card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/ar_margin_small"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="@dimen/ar_margin_normal"
            android:background="@drawable/ar_bg_love_card"
            android:clickable="true"
            android:focusable="true"
            android:minHeight="140dp">
            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ar_ic_heart"
                app:tint="?attr/arPositiveColor"
                android:contentDescription="@null"/>
            <TextView
                style="@style/AR.TextAppearance.Headline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/ar_margin_small"
                android:text="@string/ar_binary_love_title"
                android:textColor="?attr/arPositiveColor"/>
            <TextView
                style="@style/AR.TextAppearance.Microcopy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ar_binary_love_sub"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/ar_needs_card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/ar_margin_small"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="@dimen/ar_margin_normal"
            android:background="@drawable/ar_bg_needs_card"
            android:clickable="true"
            android:focusable="true"
            android:minHeight="140dp">
            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ar_ic_wrench"
                app:tint="?attr/arNegativeColor"
                android:contentDescription="@null"/>
            <TextView
                style="@style/AR.TextAppearance.Headline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/ar_margin_small"
                android:text="@string/ar_binary_needs_title"
                android:textColor="?attr/arNegativeColor"/>
            <TextView
                style="@style/AR.TextAppearance.Microcopy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ar_binary_needs_sub"/>
        </LinearLayout>
    </LinearLayout>

    <TextView
        style="@style/AR.TextAppearance.Microcopy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/ar_margin_small"
        android:text="@string/ar_binary_microcopy"
        android:gravity="center"/>

    <TextView
        android:id="@+id/ar_later_button"
        style="@style/AR.Button.Ghost"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/ar_min_touch_size"
        android:gravity="center"
        android:text="@string/ar_button_rate_later"
        android:clickable="true"
        android:focusable="true"/>

    <TextView
        android:id="@+id/ar_never_button"
        style="@style/AR.Button.Ghost"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/ar_min_touch_size"
        android:gravity="center"
        android:text="@string/ar_button_rate_never"
        android:textSize="@dimen/ar_text_body_small"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"/>
</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="@dimen/ar_margin_big"
    android:paddingEnd="@dimen/ar_margin_big"
    android:paddingTop="@dimen/ar_margin_normal"
    android:paddingBottom="@dimen/ar_margin_big"
    android:gravity="center_horizontal">

    <View
        android:layout_width="@dimen/ar_drag_handle_width"
        android:layout_height="@dimen/ar_drag_handle_height"
        android:layout_marginBottom="@dimen/ar_margin_normal"
        android:background="@drawable/ar_bg_drag_handle"/>

    <ImageView
        android:id="@+id/ar_icon"
        android:layout_width="@dimen/ar_icon_size"
        android:layout_height="@dimen/ar_icon_size"
        android:layout_marginBottom="@dimen/ar_margin_normal"
        android:contentDescription="@string/ar_cd_app_icon"/>

    <TextView
        android:id="@+id/ar_title"
        style="@style/AR.TextAppearance.HeadlineLarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/ar_margin_small"
        android:text="@string/ar_title_overview_emoji"
        android:gravity="center"/>

    <TextView
        android:id="@+id/ar_message"
        style="@style/AR.TextAppearance.Body"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/ar_margin_big"
        android:text="@string/ar_message_overview"
        android:gravity="center"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="@dimen/ar_margin_big"
        android:weightSum="5">

        <LinearLayout
            android:id="@+id/ar_emoji_1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:padding="@dimen/ar_margin_small">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/ar_emoji_1_char" android:textSize="@dimen/ar_emoji_size"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/ar_emoji_1" android:textSize="@dimen/ar_text_microcopy"
                android:textColor="?attr/arTextSecondaryColor"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/ar_emoji_2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:padding="@dimen/ar_margin_small">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/ar_emoji_2_char" android:textSize="@dimen/ar_emoji_size"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/ar_emoji_2" android:textSize="@dimen/ar_text_microcopy"
                android:textColor="?attr/arTextSecondaryColor"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/ar_emoji_3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:padding="@dimen/ar_margin_small">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/ar_emoji_3_char" android:textSize="@dimen/ar_emoji_size"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/ar_emoji_3" android:textSize="@dimen/ar_text_microcopy"
                android:textColor="?attr/arTextSecondaryColor"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/ar_emoji_4"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:padding="@dimen/ar_margin_small">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/ar_emoji_4_char" android:textSize="@dimen/ar_emoji_size"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/ar_emoji_4" android:textSize="@dimen/ar_text_microcopy"
                android:textColor="?attr/arTextSecondaryColor"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/ar_emoji_5"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:padding="@dimen/ar_margin_small">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/ar_emoji_5_char" android:textSize="@dimen/ar_emoji_size"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/ar_emoji_5" android:textSize="@dimen/ar_text_microcopy"
                android:textColor="?attr/arTextSecondaryColor"/>
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/ar_later_button"
        style="@style/AR.Button.Ghost"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/ar_min_touch_size"
        android:gravity="center"
        android:text="@string/ar_button_rate_later"
        android:clickable="true"
        android:focusable="true"/>

    <TextView
        android:id="@+id/ar_never_button"
        style="@style/AR.Button.Ghost"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/ar_min_touch_size"
        android:gravity="center"
        android:text="@string/ar_button_rate_never"
        android:textSize="@dimen/ar_text_body_small"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"/>
</LinearLayout>
